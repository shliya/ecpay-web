{
    "name": "common-vote",
    "version": "1.0.0",
    "description": "shiliya common",
    "main": "index.js",
    "scripts": {
        "test": "npm run test:lcf",
        "test:lcf": "node --test test/lcf-donation.unit.test.js test/lcf-donation.integration.test.js test/lcf-donation.concurrency.test.js",
        "test:lcf-overlay": "node test/lcf-overlay-donate-list.integration.js",
        "test:lcf:unit": "node --test test/lcf-donation.unit.test.js",
        "test:lcf:concurrency": "node --test test/lcf-donation.concurrency.test.js",
        "test:lcf:http": "node --test test/lcf-donation.http.test.js",
        "dev:server": "nodemon index.js",
        "dev:client": "webpack serve --mode development",
        "dev-web": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "clean": "rimraf public/*.js public/*.html",
        "build": "webpack && node scripts/copy-static-for-public.js",
        "start": "npm run build && node index.js",
        "start:prod": "node index.js",
        "dev": "webpack serve --mode development",
        "watch": "webpack --watch --mode development",
        "backup": "node backup.js",
        "sync": "node server/lib/script/syncDB.js",
        "migrate": "node server/migration/migrate.js up",
        "migrate:status": "node server/migration/migrate.js status",
        "migrate:pending": "node server/migration/migrate.js pending",
        "migrate:bootstrap-legacy": "node server/migration/bootstrap-legacy-records.js"
    },
    "build": {
        "appId": "com.shiliya.commonvote",
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "sign": false,
            "signingHashAlgorithms": [
                "sha256"
            ]
        },
        "portable": {
            "artifactName": "CommonVote-portable.exe"
        },
        "files": [
            "dist/**/*",
            "public/**/*",
            "static/**/*",
            "server/**/*",
            "main.js",
            "index.js",
            "preload.js",
            "node_modules/**/*",
            "build/**/*",
            "assest/**/*"
        ],
        "directories": {
            "output": "release",
            "buildResources": "build"
        }
    },
    "author": "shiliyahamster",
    "license": "ISC",
    "dependencies": {
        "axios": "^1.7.7",
        "clean-webpack-plugin": "^4.0.0",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "css-loader": "^7.1.2",
        "dayjs": "^1.11.18",
        "dotenv": "^16.4.5",
        "electron-store": "^10.0.1",
        "express": "^4.21.2",
        "express-rate-limit": "^8.3.0",
        "html-webpack-plugin": "^5.6.3",
        "lodash": "^4.17.21",
        "mini-css-extract-plugin": "^2.9.2",
        "path": "^0.12.7",
        "pg": "^8.15.6",
        "pg-hstore": "^2.3.4",
        "qrcode": "^1.5.4",
        "rimraf": "^5.0.5",
        "sequelize": "^6.37.7",
        "speakeasy": "^2.0.0",
        "style-loader": "^4.0.0",
        "umzug": "^3.8.3",
        "webpack": "^5.94.0",
        "webpack-cli": "^5.1.4",
        "ws": "^8.18.3",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "concurrently": "^9.0.0",
        "electron": "^34.1.1",
        "electron-builder": "^25.1.8",
        "nodemon": "^3.1.4",
        "prettier": "^3.5.3",
        "webpack-dev-server": "^5.1.0"
    }
}
